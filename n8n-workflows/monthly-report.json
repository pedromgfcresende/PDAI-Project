{
  "name": "Monthly Report",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 8,
              "triggerAtDayOfMonth": 1
            }
          ]
        }
      },
      "name": "1st of Month 8am Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "http://host.docker.internal:8000/pipeline/monthly",
        "method": "POST",
        "options": {
          "timeout": 900000
        }
      },
      "name": "Run Monthly Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300]
    }
  ],
  "connections": {
    "1st of Month 8am Trigger": {
      "main": [
        [
          {
            "node": "Run Monthly Pipeline",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
